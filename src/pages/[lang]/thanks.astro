---
import ThanksPage from '../../components/ThanksPage.astro';
import { type Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'pl' } },
    { params: { lang: 'de' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params as { lang: Locale };
---

<ThanksPage lang={lang} />
