---
import { locales, localizedPath, type Locale, getDictionary } from '../i18n/utils';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

// Shared chrome (head, nav, footer, dark theme) for `privacy` and `support`
// pages. Per-page content goes in the default slot.  `simple` mode hides the
// nav and footer — used by `thanks` which is a centered confirmation card.

interface Props {
  lang: Locale;
  pageKey: 'privacy' | 'support' | 'thanks';
  title: string;
  description: string;
  noindex?: boolean;
  simple?: boolean;
}

const { lang, pageKey, title, description, noindex = false, simple = false } = Astro.props;
const t = getDictionary(lang);

const homePath = localizedPath('/', lang);
const supportPath = localizedPath('/support', lang);
const privacyPath = localizedPath('/privacy', lang);
const blogPath = localizedPath('/blog', lang);

const canonicalPath = localizedPath(`/${pageKey}`, lang) + '/';
const canonicalURL = new URL(canonicalPath, Astro.site).toString();
const pathname = Astro.url.pathname;

const fullTitle = `${title} – PoGoTeams`;
---
<!DOCTYPE html>
<html lang={t.lang.html}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <meta name="theme-color" content="#120818">
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'}>
  <link rel="canonical" href={canonicalURL}>

  {!noindex && (
    <>
      {locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={new URL(localizedPath(`/${pageKey}`, loc) + '/', Astro.site).toString()}
        />
      ))}
      <link rel="alternate" hreflang="x-default" href={new URL(`/${pageKey}/`, Astro.site).toString()} />
    </>
  )}

  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://pogoteams.app/assets/og-image.png?v=1">
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:site_name" content="PoGoTeams">
  <meta property="og:locale" content={t.lang.ogLocale}>

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>

  <slot name="head" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/assets/app-icon.png">
  <link rel="apple-touch-icon" href="/assets/icon180.png">

  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg-dark: #120818;
      --bg-card: #1a0f1f;
      --accent: #A631D8;
      --accent-light: #c45ef0;
      --text-primary: #ffffff;
      --text-secondary: #b8a8c0;
      --text-muted: #6b5a73;
    }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-primary);
      line-height: 1.7;
      min-height: 100vh;
    }
    a { color: var(--accent-light); }
  </style>

  <style>
    nav {
      padding: 1rem 2rem;
      background: rgba(18, 8, 24, 0.9);
      border-bottom: 1px solid rgba(166, 49, 216, 0.1);
    }
    .nav-content {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-logo { height: 28px; }
    .nav-back {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }
    .nav-back:hover { color: var(--accent-light); }

    main {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
    }
    main :global(h1) {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 2rem;
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    footer {
      padding: 2rem;
      border-top: 1px solid rgba(166, 49, 216, 0.1);
      text-align: center;
    }
    .footer-links {
      display: flex;
      gap: 2rem;
      justify-content: center;
      list-style: none;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .footer-links a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
    }
    .footer-links a:hover { color: var(--accent-light); }
    .footer-lang { margin-bottom: 1rem; display: flex; justify-content: center; }
    .footer-copyright {
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .simple-body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      min-height: 100vh;
    }

    @media (max-width: 600px) {
      main {
        padding: 2rem 1.5rem 3rem;
      }
      main :global(h1) {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body class:list={[{ 'simple-body': simple }]}>
  {!simple && (
    <nav>
      <div class="nav-content">
        <a href={homePath}>
          <img src="/assets/logo_horizontal.png" alt="PoGoTeams" class="nav-logo">
        </a>
        <a href={homePath} class="nav-back">{t.legal.backToHome}</a>
      </div>
    </nav>
  )}

  {simple ? (
    <slot />
  ) : (
    <main>
      <slot />
    </main>
  )}

  {!simple && (
    <footer>
      <ul class="footer-links">
        <li><a href={homePath}>{t.nav.home}</a></li>
        {pageKey !== 'privacy' && <li><a href={privacyPath}>{t.footer.privacy}</a></li>}
        {pageKey !== 'support' && <li><a href={supportPath}>{t.footer.support}</a></li>}
        <li><a href={blogPath}>{t.footer.blog}</a></li>
      </ul>
      <div class="footer-lang">
        <LanguageSwitcher lang={lang} pathname={pathname} />
      </div>
      <p class="footer-copyright">{t.footer.copyright}</p>
    </footer>
  )}

  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "229b36c080104f4f808b7b4ddd334d3d"}'></script>
</body>
</html>
